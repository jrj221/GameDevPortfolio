{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    // Vite performs the actual build; this tsconfig is type-checking only, so
    // noEmit lets us include ../shared without a rootDir/output-layout conflict.
     "noEmit": true,

    // File Layout
    "outDir": "dist",
    // rootDir spans the repo root so the shared/ workspace (included below for
    // type-checking) isn't flagged as outside the source root.
    "rootDir": "..",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "types": [ "node", "vite/client" ],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    // "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": [ "src", "src/scripts/BucketUpload.ts", "../shared" ]
}
